{
  "name": "google-filesearch-rag",
  "version": "1.0.0",
  "description": "Google Gemini API File Search RAG Agent",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "start": "node server.js",
    "start:ts": "node dist/server.js",
    "dev": "node server.js",
    "dev:ts": "ts-node src/server.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "example:rag": "node example-rag-agent.js",
    "example:import": "node example-import-workflow.js import",
    "example:compare": "node example-import-workflow.js compare",
    "example:chunking": "node example-chunking.js",
    "example:store": "node example-store-management.js",
    "example:metadata": "node example-metadata.js",
    "example:manager": "node example.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docker:build": "docker build -t filesearch-rag .",
    "docker:run": "docker run -p 8080:8080 --env-file .env filesearch-rag",
    "gcp:build": "gcloud builds submit --tag gcr.io/ts-back-nest-479305/filesearch-rag",
    "gcp:deploy": "gcloud run deploy filesearch-rag --image gcr.io/ts-back-nest-479305/filesearch-rag --platform managed --region asia-northeast3 --allow-unauthenticated",
    "gcp:logs": "gcloud run services logs tail filesearch-rag --region asia-northeast3"
  },
  "keywords": [
    "gemini",
    "google",
    "ai",
    "rag",
    "file-search",
    "retrieval-augmented-generation"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/genai": "^1.29.1",
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.6.0",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  }
}
