generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 사용자 유형 ====================

enum UserType {
  PERSONAL   // 개인
  BUSINESS   // 기업
}

enum SubscriptionTier {
  FREE           // 개인 무료
  PRO            // 개인 유료
  BIZ_STANDARD   // 기업 스탠다드
  BIZ_PREMIUM    // 기업 프리미엄
}

// ==================== 사용자 ====================

model User {
  id                String           @id  // Firebase UID를 PK로 사용
  email             String           @unique
  displayName       String?
  photoUrl          String?
  userType          UserType         @default(PERSONAL)
  subscriptionTier  SubscriptionTier @default(FREE)
  subscriptionExpiry DateTime?

  // 기업 소속 (기업 사용자인 경우)
  organizationId    String?
  role              String?          // 'owner' | 'admin' | 'member'

  // 사용량 추적
  dailyChatCount    Int              @default(0)
  dailyChatResetAt  DateTime?
  monthlyDocCount   Int              @default(0)
  monthlyEvidenceCount Int           @default(0)
  monthlyResetAt    DateTime?

  // 온보딩
  onboardingCompleted Boolean        @default(false)
  termsAgreedAt     DateTime?
  privacyAgreedAt   DateTime?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization      Organization?    @relation(fields: [organizationId], references: [id])
  cases             LegalCase[]
  chatSessions      ChatSession[]

  @@index([organizationId])
  @@index([userType])
  @@index([subscriptionTier])
}

// ==================== 기업/조직 ====================

model Organization {
  id                String           @id @default(cuid())
  name              String           // 회사명
  businessNumber    String?          @unique  // 사업자등록번호
  industry          String?          // 업종
  employeeCount     String?          // 직원 규모 ('1-10', '11-50', '51-200', '200+')
  address           String?
  contactName       String?          // 담당자 이름
  contactPhone      String?
  contactEmail      String?

  // 요금제
  subscriptionTier  SubscriptionTier @default(BIZ_STANDARD)
  subscriptionExpiry DateTime?
  maxSeats          Int              @default(5)  // 최대 팀원 수

  // 사내 규정 RAG
  companyRulesStoreId String?        // 사내 규정 전용 RAG 스토어 ID

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  members           User[]
  caseTags          CaseTag[]

  @@index([businessNumber])
}

// ==================== 기업 사건 태그 ====================

model CaseTag {
  id              String   @id @default(cuid())
  organizationId  String
  caseId          String
  tag             String           // '진행중' | '완료' | '검토필요' | 커스텀 태그
  priority        String?  @default("normal")  // 'high' | 'normal' | 'low'
  assigneeId      String?          // 담당자 User ID

  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case            LegalCase    @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([organizationId, caseId, tag])
  @@index([organizationId])
  @@index([caseId])
}

// ==================== 사건 관리 ====================

model LegalCase {
  id          String   @id @default(cuid())
  userId      String
  organizationId String?  // 기업 소속 사건인 경우
  description String   @db.Text
  caseType    String   @default("")
  legalDomain String   @default("labor")  // 법 분야: labor, civil, criminal, family, admin, ip, corporate
  currentStep Int      @default(0)

  // Build 시스템 메타
  analysisCount Int    @default(0)
  chatCount     Int    @default(0)
  evidenceCount Int    @default(0)
  insightCount  Int    @default(0)
  lastAnalyzedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user              User?            @relation(fields: [userId], references: [id])
  issues            CaseIssue[]
  laws              CaseLaw[]
  chatSessions      ChatSession[]
  analysisVersions  AnalysisVersion[]
  insights          CaseInsight[]
  timeline          CaseTimeline[]
  updates           CaseUpdate[]
  evidence          CaseEvidence[]
  tags              CaseTag[]

  @@map("LaborCase")
  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
}

// ==================== 증거/자료 ====================

model CaseEvidence {
  id              String   @id @default(cuid())
  caseId          String
  fileName        String
  fileType        String   // 'image' | 'pdf' | 'text'
  mimeType        String
  fileSize        Int
  fileUrl         String?  // Firebase Storage URL (30일 임시 보관)
  extractedText   String   @db.Text   // Gemini Vision 추출 텍스트
  structuredData  Json?    // 구조화된 추출 결과 (항목별)
  sourceLabel     String   @default("")  // 사용자 레이블 (예: "근로계약서", "급여명세서")
  expiresAt       DateTime?  // 원본 파일 만료일
  createdAt       DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

// ==================== 사건 업데이트 (보충/경과) ====================

model CaseUpdate {
  id        String   @id @default(cuid())
  caseId    String
  type      String   // 'supplement' (빠뜨린 내용) | 'progress' (새 진행상황)
  content   String   @db.Text
  createdAt DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, type])
}

// ==================== 쟁점 ====================

model CaseIssue {
  id          String   @id @default(cuid())
  caseId      String
  title       String
  summary     String   @db.Text
  severity    String   @default("medium")
  isUserAdded Boolean  @default(false)
  createdAt   DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

// ==================== 법령 ====================

model CaseLaw {
  id        String   @id @default(cuid())
  caseId    String
  title     String
  type      String
  detail    String   @db.Text
  issueId   String?
  createdAt DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

// ==================== 분석 버전 히스토리 ====================

model AnalysisVersion {
  id        String   @id @default(cuid())
  caseId    String
  stepName  String   // 'issueAnalysis' | 'lawAnalysis'
  version   Int
  trigger   String   @default("manual")  // 'manual' | 'evidence_added' | 'description_updated'
  data      Json     // 분석 결과 전체 (issues, nodes, links, summary 등)
  diff      Json?    // 이전 버전과의 차이
  createdAt DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, stepName])
}

// ==================== 인사이트 ====================

model CaseInsight {
  id        String   @id @default(cuid())
  caseId    String
  content   String   @db.Text
  type      String   @default("user_memo")  // 'ai_extracted' | 'user_memo'
  source    String   @default("manual")
  createdAt DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

// ==================== 타임라인 ====================

model CaseTimeline {
  id        String   @id @default(cuid())
  caseId    String
  type      String   // 'case_created' | 'issue_analyzed' | 'law_analyzed' | 'reanalyzed' | 'description_updated' | 'insight_added' | 'chat_started'
  detail    String
  version   Int?
  trigger   String?
  metadata  Json?    // 추가 데이터 (oldDescriptionPreview 등)
  createdAt DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, createdAt])
}

// ==================== 채팅 ====================

model ChatSession {
  id           String   @id @default(cuid())
  caseId       String?
  userId       String
  systemPrompt String   @db.Text
  createdAt    DateTime @default(now())

  user     User?          @relation(fields: [userId], references: [id])
  messages ChatMessage[]
  case     LegalCase?     @relation(fields: [caseId], references: [id])

  @@index([userId])
  @@index([caseId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}
